# =============================================================================
# Course Bot — Master Environment Template
# =============================================================================
# Copy this file and fill in the values:
#   cp env.example .env && source .env
#
# Engine-specific LLM keys: see engine/env.example
# =============================================================================

# -- Slack Bot --
export SLACK_SIGNING_SECRET=
export SLACK_BOT_TOKEN=xoxb-...

# -- GCP --
export GCP_PROJECT_ID=course-bot-490222
export GCP_REGION=europe-west1

# -- Claude --
export CLAUDE_CODE_OAUTH_TOKEN=
export CLAUDE_AGENT_DIR=./engine
export CLAUDE_RESPONSE_TIMEOUT=5400

# -- Cloud Run Job dispatch --
export JOB_NAME=course-bot-worker-dev
export MAX_CONCURRENT_JOBS=5

# -- Workspace isolation (optional, for per-thread git clones) --
# export REPO_URL=https://github.com/IGRDA/course-bot.git
# export DEFAULT_BRANCH=main

# -- TTS Gateway (Qwen TTS API voice cloning) --
export CLOUD_GATEWAY_API_KEY=

# -- Engine API keys (minimum for course generation) --
export MISTRAL_API_KEY=
export MISTRAL_MODEL_NAME=mistral-small-latest
export GOOGLE_BOOKS_API_KEY=
export YOUTUBE_API_KEY=
